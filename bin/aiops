#!/usr/bin/env python3
"""Small local client for aiops-execd HTTPS gateways."""

from __future__ import annotations

import argparse
import json
import os
import re
import secrets
import shlex
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from dataclasses import dataclass
from pathlib import Path
from typing import Any


DEFAULT_TIMEOUT = 60
DEFAULT_WAIT = 25
DEFAULT_TAIL = 200
MAX_POLL_EXTRA = 30
NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_.@:/-]{0,200}$")
ENV_KEY_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")
STEP_EVENT_PREFIX = "__AIOPS_STEP_JSON__" + secrets.token_hex(8) + "__"
OUTPUT_RAW = "raw"
OUTPUT_JSON = "json"
OUTPUT_AGENT_JSON = "agent-json"


@dataclass
class HostConfig:
    name: str
    base: str
    run_token: str
    root_token: str
    default_privilege: str
    output_mode: str = OUTPUT_AGENT_JSON


class AiopsError(Exception):
    pass


class AiopsHTTPError(AiopsError):
    def __init__(self, code: int, payload: Any):
        self.code = code
        self.payload = payload
        message = payload.get("error", payload) if isinstance(payload, dict) else payload
        super().__init__(f"HTTP {code}: {message}")


def repo_env_path() -> Path:
    return Path(__file__).resolve().parents[1] / ".env"


def parse_env_value(raw_value: str, path: Path, line_no: int) -> str:
    value = raw_value.strip()
    if not value:
        return ""
    if value[0] in {"'", '"'}:
        try:
            parts = shlex.split(value, comments=True, posix=True)
        except ValueError as exc:
            raise AiopsError(f"{path}:{line_no}: invalid quoted value: {exc}") from exc
        if len(parts) != 1:
            raise AiopsError(f"{path}:{line_no}: quoted env value must be a single token")
        return parts[0]
    return re.split(r"\s+#", value, maxsplit=1)[0].strip()


def load_env_file(path: Path) -> dict[str, str]:
    env: dict[str, str] = {}
    if not path.exists():
        return env
    for line_no, raw in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[7:].lstrip()
        if "=" not in line:
            raise AiopsError(f"{path}:{line_no}: expected KEY=VALUE")
        key, value = line.split("=", 1)
        key = key.strip()
        if not ENV_KEY_RE.match(key):
            raise AiopsError(f"{path}:{line_no}: invalid env key {key!r}")
        env[key] = parse_env_value(value, path, line_no)
    return env


def merged_env() -> dict[str, str]:
    env = dict(os.environ)
    env_file = Path(os.environ.get("AIOPS_ENV_FILE", repo_env_path()))
    env.update(load_env_file(env_file))
    env["AIOPS_ENV_FILE_RESOLVED"] = str(env_file)
    return env


def sanitize_host(host: str) -> str:
    return re.sub(r"[^A-Za-z0-9]+", "_", host).strip("_").upper()


def split_csv(value: str) -> list[str]:
    return [item.strip() for item in value.split(",") if item.strip()]


def known_hosts(env: dict[str, str]) -> list[str]:
    hosts: list[str] = []
    default = env.get("AIOPS_DEFAULT_HOST", "").strip()
    if default:
        hosts.append(default)
    hosts.extend(split_csv(env.get("AIOPS_HOSTS", "")))
    return sorted(dict.fromkeys(hosts))


def canonical_host(input_host: str, env: dict[str, str]) -> str:
    requested = input_host.strip()
    if requested == "default":
        default = env.get("AIOPS_DEFAULT_HOST", "").strip()
        if default:
            return default
    candidates = known_hosts(env)
    if not candidates and env.get("AIOPS_HTTPS_BASE"):
        return requested
    for host in candidates:
        if requested == host:
            return host
        aliases = split_csv(env.get(f"AIOPS_HOST_{sanitize_host(host)}_ALIASES", ""))
        if requested in aliases:
            return host
    return requested


def host_config(input_host: str, env: dict[str, str]) -> HostConfig:
    host = canonical_host(input_host, env)
    key = sanitize_host(host)
    base = env.get(f"AIOPS_HOST_{key}_BASE")
    run_token = env.get(f"AIOPS_HOST_{key}_RUN_TOKEN")
    root_token = env.get(f"AIOPS_HOST_{key}_ROOT_TOKEN")

    default = env.get("AIOPS_DEFAULT_HOST", "").strip()
    aliases = split_csv(env.get(f"AIOPS_HOST_{sanitize_host(default)}_ALIASES", "")) if default else []
    can_use_legacy = bool(env.get("AIOPS_HTTPS_BASE")) and (
        not default or host == default or input_host in aliases or input_host == "default"
    )
    if can_use_legacy:
        base = base or env.get("AIOPS_HTTPS_BASE")
        run_token = run_token or env.get("AIOPS_RUN_TOKEN")
        root_token = root_token or env.get("AIOPS_ROOT_TOKEN")

    missing = []
    if not base:
        missing.append("BASE")
    if not run_token:
        missing.append("RUN_TOKEN")
    if not root_token:
        missing.append("ROOT_TOKEN")
    if missing:
        raise AiopsError(
            f"host {input_host!r} is missing {', '.join(missing)} in {env.get('AIOPS_ENV_FILE_RESOLVED')}"
        )

    default_privilege = env.get(f"AIOPS_HOST_{key}_DEFAULT_PRIVILEGE") or env.get("AIOPS_DEFAULT_PRIVILEGE", "root")
    if default_privilege not in {"root", "user"}:
        default_privilege = "root"
    return HostConfig(
        name=host,
        base=base.rstrip("/"),
        run_token=run_token,
        root_token=root_token,
        default_privilege=default_privilege,
        output_mode=default_output_mode(env),
    )


def default_output_mode(env: dict[str, str]) -> str:
    if env.get("AIOPS_AGENT_JSON") == "1":
        return OUTPUT_AGENT_JSON
    raw = env.get("AIOPS_OUTPUT", "").strip().lower()
    if raw == "":
        return OUTPUT_AGENT_JSON
    if raw in {"raw", "human"}:
        return OUTPUT_RAW
    if raw in {"agent", "agent-json"}:
        return OUTPUT_AGENT_JSON
    if raw == "json":
        return OUTPUT_JSON
    raise AiopsError("AIOPS_OUTPUT must be raw, json, or agent-json")


def http_json(method: str, url: str, token: str | None = None, body: Any | None = None, timeout: int = 30) -> tuple[int, Any]:
    headers: dict[str, str] = {}
    data = None
    if token:
        headers["Authorization"] = "Bearer " + token
    if body is not None:
        data = json.dumps(body, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json"
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            text = resp.read().decode("utf-8", errors="replace")
            return resp.status, json.loads(text) if text else None
    except urllib.error.HTTPError as exc:
        text = exc.read().decode("utf-8", errors="replace")
        try:
            payload = json.loads(text)
        except json.JSONDecodeError:
            payload = {"error": text}
        raise AiopsHTTPError(exc.code, payload) from exc
    except urllib.error.URLError as exc:
        raise AiopsError(f"request failed: {exc}") from exc


def token_for(host: HostConfig, privilege: str) -> str:
    return host.root_token if privilege == "root" else host.run_token


def print_json_object(payload: dict[str, Any]) -> None:
    print(json.dumps(payload, ensure_ascii=False, sort_keys=True))


def extract_agent_step_events(stdout: str) -> tuple[str, list[dict[str, int]]]:
    clean_lines: list[str] = []
    steps: list[dict[str, int]] = []
    for line in stdout.splitlines(keepends=True):
        raw = line.rstrip("\r\n")
        if raw.startswith(STEP_EVENT_PREFIX):
            try:
                event = json.loads(raw[len(STEP_EVENT_PREFIX) :])
            except json.JSONDecodeError:
                clean_lines.append(line)
                continue
            if event.get("event") == "end":
                steps.append(
                    {
                        "index": int(event.get("index", 0)),
                        "exit_code": int(event.get("exit_code", 1)),
                        "duration_sec": int(event.get("duration_sec", 0)),
                    }
                )
            continue
        clean_lines.append(line)
    return "".join(clean_lines), steps


def agent_result_payload(host: HostConfig, payload: dict[str, Any]) -> dict[str, Any]:
    exit_code = int(payload.get("exit_code", 1))
    state = payload.get("state", "failed")
    stdout, steps = extract_agent_step_events(payload.get("stdout") or "")
    result = {
        "schema": "aiops.cli.result.v1",
        "ok": state == "succeeded" and exit_code == 0,
        "host": host.name,
        "job_id": payload.get("job_id"),
        "state": state,
        "exit_code": exit_code,
        "timed_out": bool(payload.get("timed_out", False)),
        "duration_ms": payload.get("duration_ms", 0),
        "stdout": stdout,
        "stderr": payload.get("stderr") or "",
        "stdout_truncated": bool(payload.get("stdout_truncated", False)),
        "stderr_truncated": bool(payload.get("stderr_truncated", False)),
        "stdout_log_truncated": bool(payload.get("stdout_log_truncated", False)),
        "stderr_log_truncated": bool(payload.get("stderr_log_truncated", False)),
        "error": payload.get("error") or "",
    }
    if steps:
        result["steps"] = steps
    return result


def error_output_mode(argv: list[str], env: dict[str, str] | None = None) -> str:
    flags = cli_tokens_before_command(argv)
    if "--raw" in flags:
        return OUTPUT_RAW
    if "--agent-json" in flags or os.environ.get("AIOPS_AGENT_JSON") == "1":
        return OUTPUT_AGENT_JSON
    if env is not None:
        return default_output_mode(env)
    return OUTPUT_AGENT_JSON


def cli_tokens_before_command(argv: list[str]) -> list[str]:
    if "--" in argv:
        return argv[: argv.index("--")]
    return argv


def agent_error_payload(host: str | None, exc: AiopsError) -> dict[str, Any]:
    code = "cli_error"
    message = str(exc)
    http_status = 0
    retry_after_sec = 0
    if isinstance(exc, AiopsHTTPError):
        http_status = exc.code
        if isinstance(exc.payload, dict):
            code = str(exc.payload.get("code") or "http_error")
            message = str(exc.payload.get("error") or message)
            retry_after_sec = int(exc.payload.get("retry_after_sec") or 0)
        else:
            code = "http_error"
    return {
        "schema": "aiops.cli.error.v1",
        "ok": False,
        "host": host or "",
        "code": code,
        "message": message,
        "http_status": http_status,
        "retry_after_sec": retry_after_sec,
    }


def run_remote(
    host: HostConfig,
    req: dict[str, Any],
    *,
    follow: bool = True,
    json_output: bool = False,
    agent_json: bool = False,
    output_mode: str | None = None,
    busy_retries: int = 6,
) -> int:
    mode = output_mode or (OUTPUT_AGENT_JSON if agent_json else OUTPUT_JSON if json_output else host.output_mode)
    privilege = req.get("privilege", host.default_privilege)
    token = token_for(host, privilege)
    status = 0
    payload: Any = None
    for attempt in range(max(0, busy_retries) + 1):
        try:
            status, payload = http_json(
                "POST",
                host.base + "/v1/run",
                token,
                req,
                timeout=max(30, int(req["wait_sec"]) + 10),
            )
            break
        except AiopsHTTPError as exc:
            is_busy = (
                exc.code == 409
                and isinstance(exc.payload, dict)
                and (exc.payload.get("code") == "executor_busy" or exc.payload.get("error") == "executor is busy")
            )
            if not is_busy or attempt >= busy_retries:
                raise
            retry_after = 1
            if isinstance(exc.payload, dict):
                retry_after = int(exc.payload.get("retry_after_sec") or retry_after)
            time.sleep(max(1, retry_after))
    if status == 202 and follow:
        payload = poll_job(host, token, payload["job_id"], int(req["timeout_sec"]))
    elif status == 202:
        if mode == OUTPUT_AGENT_JSON:
            print_json_object(agent_job_payload(host, payload))
        elif mode == OUTPUT_JSON:
            print(json.dumps(payload, ensure_ascii=False, indent=2))
        else:
            print(f"job_id={payload['job_id']} state={payload['state']}")
        return 0
    elif isinstance(payload, dict) and payload.get("result"):
        payload = payload["result"]

    if mode == OUTPUT_AGENT_JSON:
        print_json_object(agent_result_payload(host, payload))
    elif mode == OUTPUT_JSON:
        print(json.dumps(payload, ensure_ascii=False, indent=2))
    else:
        stdout = payload.get("stdout") or ""
        stderr = payload.get("stderr") or ""
        if stdout:
            sys.stdout.write(stdout)
            if not stdout.endswith("\n"):
                sys.stdout.write("\n")
        if stderr:
            sys.stderr.write(stderr)
            if not stderr.endswith("\n"):
                sys.stderr.write("\n")

    exit_code = int(payload.get("exit_code", 1))
    state = payload.get("state", "failed")
    if mode != OUTPUT_AGENT_JSON and (state != "succeeded" or exit_code != 0):
        print(f"[aiops] host={host.name} job={payload.get('job_id')} state={state} exit_code={exit_code}", file=sys.stderr)
    if exit_code == 0 and state == "succeeded":
        return 0
    return exit_code if 1 <= exit_code <= 125 else 1


def poll_job(host: HostConfig, token: str, job_id: str, timeout_sec: int) -> dict[str, Any]:
    deadline = time.time() + timeout_sec + MAX_POLL_EXTRA
    while time.time() < deadline:
        _, payload = http_json("GET", host.base + f"/v1/jobs/{urllib.parse.quote(job_id)}", token, timeout=30)
        if payload.get("state") not in {"queued", "running"}:
            return payload.get("result") or payload
        time.sleep(1)
    raise AiopsError(f"job {job_id} did not finish before local poll timeout")


def agent_job_payload(host: HostConfig, payload: dict[str, Any]) -> dict[str, Any]:
    return {
        "schema": "aiops.cli.job.v1",
        "ok": True,
        "host": host.name,
        "job_id": payload.get("job_id"),
        "state": payload.get("state", "queued"),
        "started_at": payload.get("started_at", ""),
    }


def base_run_request(args: argparse.Namespace, cmd: str, host: HostConfig) -> dict[str, Any]:
    privilege = "user" if args.user else "root" if args.root else host.default_privilege
    req = {
        "mode": "shell",
        "cmd": cmd,
        "privilege": privilege,
        "cwd": args.cwd,
        "timeout_sec": args.timeout,
        "wait_sec": min(args.wait, args.timeout),
        "kill_grace_sec": args.kill_grace,
        "max_stdout_bytes": args.max_stdout_bytes,
        "max_stderr_bytes": args.max_stderr_bytes,
        "max_stdout_log_bytes": args.max_stdout_log_bytes,
        "max_stderr_log_bytes": args.max_stderr_log_bytes,
    }
    if args.lock_key:
        req["lock_key"] = args.lock_key
    if args.idempotency_key:
        req["idempotency_key"] = args.idempotency_key
    return req


def add_run_options(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--root", action="store_true", help="run with the root-capable token")
    parser.add_argument("--user", action="store_true", help="run with the unprivileged token")
    parser.add_argument("--cwd", default="", help="remote working directory; empty uses the server default")
    parser.add_argument("--timeout", type=int, default=DEFAULT_TIMEOUT, help="remote command timeout in seconds")
    parser.add_argument("--wait", type=int, default=DEFAULT_WAIT, help="initial HTTP wait time in seconds")
    parser.add_argument("--kill-grace", type=int, default=3, help="SIGTERM grace period before SIGKILL")
    add_output_options(parser)
    parser.add_argument("--no-follow", action="store_true", help="do not poll async jobs")
    parser.add_argument("--busy-retries", type=int, default=6, help="retry POST /v1/run when the host executor is busy")
    parser.add_argument("--lock-key", default="", help="reject concurrent jobs with the same lock key")
    parser.add_argument("--idempotency-key", default="", help="reuse a matching existing job for retry-safe requests")
    parser.add_argument("--max-stdout-bytes", type=int, default=262144)
    parser.add_argument("--max-stderr-bytes", type=int, default=262144)
    parser.add_argument("--max-stdout-log-bytes", type=int, default=1048576)
    parser.add_argument("--max-stderr-log-bytes", type=int, default=1048576)


def add_output_options(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--raw", action="store_true", help="print raw stdout/stderr")
    parser.add_argument("--json", action="store_true", help="print the full result JSON")
    parser.add_argument("--agent-json", action="store_true", help="print a stable one-object JSON result for agents")


def parse_run(rest: list[str], host: HostConfig) -> int:
    parser = argparse.ArgumentParser(prog="aiops <host>", description="Run a shell command through aiops-execd")
    add_run_options(parser)
    parser.add_argument("cmd", nargs=argparse.REMAINDER)
    args = parser.parse_args(rest)
    if args.root and args.user:
        raise AiopsError("--root and --user are mutually exclusive")
    validate_run_options(args)
    cmd_parts = args.cmd
    if cmd_parts and cmd_parts[0] == "--":
        cmd_parts = cmd_parts[1:]
    if not cmd_parts:
        parser.error("missing command")
    cmd = shell_command_from_parts(cmd_parts)
    req = base_run_request(args, cmd, host)
    return run_remote(host, req, follow=not args.no_follow, output_mode=selected_output_mode(args, host), busy_retries=args.busy_retries)


def selected_output_mode(args: argparse.Namespace, host: HostConfig) -> str:
    selected = int(bool(args.raw)) + int(bool(args.json)) + int(bool(args.agent_json))
    if selected > 1:
        raise AiopsError("--raw, --json, and --agent-json are mutually exclusive")
    if args.raw:
        return OUTPUT_RAW
    if args.json:
        return OUTPUT_JSON
    if args.agent_json:
        return OUTPUT_AGENT_JSON
    return host.output_mode


def shell_command_from_parts(cmd_parts: list[str]) -> str:
    if len(cmd_parts) == 1:
        return cmd_parts[0]
    return " ".join(shlex.quote(part) for part in cmd_parts)


def batch_script(commands: list[str], stop_on_error: bool, agent_json: bool = False) -> str:
    if agent_json:
        lines = [
            "set +e",
            "__aiops_batch_failed=0",
            f"__aiops_batch_stop={1 if stop_on_error else 0}",
            "__aiops_step() {",
            "  __idx=\"$1\"",
            "  __cmd=\"$2\"",
            f"  printf '\\n{STEP_EVENT_PREFIX}{{\"index\":%s,\"event\":\"begin\"}}\\n' \"$__idx\"",
            "  __start=$(date +%s)",
            "  /bin/bash --noprofile --norc -o pipefail -c \"$__cmd\"",
            "  __rc=$?",
            "  __end=$(date +%s)",
            f"  printf '{STEP_EVENT_PREFIX}{{\"index\":%s,\"event\":\"end\",\"exit_code\":%s,\"duration_sec\":%s}}\\n' \"$__idx\" \"$__rc\" \"$((__end-__start))\"",
            "  if [ \"$__rc\" -ne 0 ]; then",
            "    __aiops_batch_failed=\"$__rc\"",
            "    if [ \"$__aiops_batch_stop\" = \"1\" ]; then exit \"$__rc\"; fi",
            "  fi",
            "}",
        ]
        for idx, command in enumerate(commands, 1):
            lines.append(f"__aiops_step {idx} {shlex.quote(command)}")
        lines.append('exit "$__aiops_batch_failed"')
        return "\n".join(lines) + "\n"

    lines = [
        "set +e",
        "__aiops_batch_failed=0",
        f"__aiops_batch_stop={1 if stop_on_error else 0}",
        "__aiops_step() {",
        "  __idx=\"$1\"",
        "  __cmd=\"$2\"",
        "  printf '\\n===== aiops step %s begin =====\\n' \"$__idx\"",
        "  printf 'cmd: %s\\n' \"$__cmd\"",
        "  __start=$(date +%s)",
        "  /bin/bash --noprofile --norc -o pipefail -c \"$__cmd\"",
        "  __rc=$?",
        "  __end=$(date +%s)",
        "  printf '===== aiops step %s exit=%s duration_sec=%s =====\\n' \"$__idx\" \"$__rc\" \"$((__end-__start))\"",
        "  if [ \"$__rc\" -ne 0 ]; then",
        "    __aiops_batch_failed=\"$__rc\"",
        "    if [ \"$__aiops_batch_stop\" = \"1\" ]; then exit \"$__rc\"; fi",
        "  fi",
        "}",
    ]
    for idx, command in enumerate(commands, 1):
        lines.append(f"__aiops_step {idx} {shlex.quote(command)}")
    lines.append('exit "$__aiops_batch_failed"')
    return "\n".join(lines) + "\n"


def read_batch_commands(args: argparse.Namespace) -> list[str]:
    commands: list[str] = []
    commands.extend(args.cmd or [])
    if args.file:
        for raw in Path(args.file).read_text(encoding="utf-8").splitlines():
            line = raw.strip()
            if line and not line.startswith("#"):
                commands.append(line)
    positional = list(args.commands or [])
    if positional and positional[0] == "--":
        positional = positional[1:]
    commands.extend(positional)
    if not commands and not sys.stdin.isatty():
        for raw in sys.stdin.read().splitlines():
            line = raw.strip()
            if line and not line.startswith("#"):
                commands.append(line)
    return commands


def command_batch(host: HostConfig, rest: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="aiops <host> batch", description="Run multiple shell commands in one remote job")
    add_run_options(parser)
    parser.set_defaults(timeout=120)
    parser.add_argument("--cmd", action="append", help="add one shell command; repeatable")
    parser.add_argument("-f", "--file", help="read one shell command per non-empty non-comment line")
    parser.add_argument("--stop-on-error", action="store_true", help="stop after the first failed step")
    parser.add_argument("commands", nargs=argparse.REMAINDER, help="optional command strings after --")
    args = parser.parse_args(rest)
    if args.root and args.user:
        raise AiopsError("--root and --user are mutually exclusive")
    validate_run_options(args)
    commands = read_batch_commands(args)
    if not commands:
        raise AiopsError("batch requires --cmd, --file, positional commands, or stdin lines")
    output_mode = selected_output_mode(args, host)
    script = batch_script(commands, args.stop_on_error, agent_json=output_mode == OUTPUT_AGENT_JSON)
    req = base_run_request(args, script, host)
    return run_remote(host, req, follow=not args.no_follow, output_mode=output_mode, busy_retries=args.busy_retries)


def command_health(host: HostConfig) -> int:
    _, payload = http_json("GET", host.base + "/healthz", timeout=15)
    print(json.dumps(payload, ensure_ascii=False))
    return 0


def command_job(host: HostConfig, rest: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="aiops <host> job")
    parser.add_argument("job_id")
    parser.add_argument("--user", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args(rest)
    token = host.run_token if args.user else host.root_token
    _, payload = http_json("GET", host.base + f"/v1/jobs/{urllib.parse.quote(args.job_id)}", token, timeout=30)
    print(json.dumps(payload, ensure_ascii=False, indent=2) if args.json else json.dumps(payload, ensure_ascii=False))
    return 0


def command_output(host: HostConfig, stream: str, rest: list[str]) -> int:
    parser = argparse.ArgumentParser(prog=f"aiops <host> {stream}")
    parser.add_argument("job_id")
    parser.add_argument("--tail-bytes", type=int, default=0)
    parser.add_argument("--user", action="store_true")
    args = parser.parse_args(rest)
    require_int_range("--tail-bytes", args.tail_bytes, min_value=0)
    token = host.run_token if args.user else host.root_token
    url = host.base + f"/v1/jobs/{urllib.parse.quote(args.job_id)}/{stream}"
    if args.tail_bytes:
        url += "?tail_bytes=" + str(args.tail_bytes)
    req = urllib.request.Request(url, headers={"Authorization": "Bearer " + token}, method="GET")
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            sys.stdout.buffer.write(resp.read())
    except urllib.error.HTTPError as exc:
        text = exc.read().decode("utf-8", errors="replace")
        try:
            payload = json.loads(text)
        except json.JSONDecodeError:
            payload = {"error": text}
        raise AiopsHTTPError(exc.code, payload) from exc
    except urllib.error.URLError as exc:
        raise AiopsError(f"request failed: {exc}") from exc
    return 0


def quoted(value: str) -> str:
    return shlex.quote(value)


def require_safe_name(kind: str, value: str) -> None:
    if not NAME_RE.match(value):
        raise AiopsError(f"unsafe {kind}: {value!r}")


def require_int_range(name: str, value: int, *, min_value: int | None = None, max_value: int | None = None) -> None:
    if min_value is not None and value < min_value:
        raise AiopsError(f"{name} must be >= {min_value}")
    if max_value is not None and value > max_value:
        raise AiopsError(f"{name} must be <= {max_value}")


def validate_run_options(args: argparse.Namespace) -> None:
    require_int_range("--timeout", args.timeout, min_value=1)
    require_int_range("--wait", args.wait, min_value=0)
    require_int_range("--kill-grace", args.kill_grace, min_value=1, max_value=30)
    require_int_range("--busy-retries", args.busy_retries, min_value=0)
    for name in (
        "max_stdout_bytes",
        "max_stderr_bytes",
        "max_stdout_log_bytes",
        "max_stderr_log_bytes",
    ):
        require_int_range("--" + name.replace("_", "-"), int(getattr(args, name)), min_value=0)
    if args.lock_key:
        require_safe_name("lock key", args.lock_key)
    if args.idempotency_key:
        require_safe_name("idempotency key", args.idempotency_key)


def run_builtin(
    host: HostConfig,
    cmd: str,
    *,
    timeout: int = DEFAULT_TIMEOUT,
    output_mode: str | None = None,
    json_output: bool = False,
) -> int:
    class Args:
        root = True
        user = False
        cwd = "/"
        wait = DEFAULT_WAIT
        kill_grace = 3
        max_stdout_bytes = 262144
        max_stderr_bytes = 262144
        max_stdout_log_bytes = 1048576
        max_stderr_log_bytes = 1048576
        lock_key = ""
        idempotency_key = ""

    args = Args()
    args.timeout = timeout
    req = base_run_request(args, cmd, host)
    mode = output_mode or (OUTPUT_JSON if json_output else host.output_mode)
    return run_remote(host, req, follow=True, output_mode=mode)


def command_inspect(host: HostConfig, rest: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="aiops <host> inspect")
    add_output_options(parser)
    args = parser.parse_args(rest)
    cmd = r"""set -e
echo '## host'; hostname; uptime
echo '## memory'; free -h
echo '## disk'; df -h /
echo '## docker'; docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' 2>&1 || true
echo '## services'; systemctl is-active aiops-execd docker nginx caddy 2>/dev/null || true
"""
    return run_builtin(host, cmd, timeout=30, output_mode=selected_output_mode(args, host))


def command_docker(host: HostConfig, rest: list[str]) -> int:
    if not rest:
        raise AiopsError("docker subcommand required: ps|logs|restart")
    sub = rest[0]
    if sub == "ps":
        parser = argparse.ArgumentParser(prog="aiops <host> docker ps")
        parser.add_argument("--all", "-a", action="store_true")
        add_output_options(parser)
        args = parser.parse_args(rest[1:])
        all_flag = "-a " if args.all else ""
        return run_builtin(
            host,
            f"docker ps {all_flag}--format 'table {{{{.Names}}}}\\t{{{{.Status}}}}\\t{{{{.Ports}}}}'",
            output_mode=selected_output_mode(args, host),
        )
    if sub == "logs":
        parser = argparse.ArgumentParser(prog="aiops <host> docker logs")
        parser.add_argument("container")
        parser.add_argument("--tail", type=int, default=DEFAULT_TAIL)
        add_output_options(parser)
        args = parser.parse_args(rest[1:])
        require_int_range("--tail", args.tail, min_value=1)
        require_safe_name("container", args.container)
        return run_builtin(
            host,
            f"docker logs --tail={int(args.tail)} {quoted(args.container)} 2>&1",
            timeout=60,
            output_mode=selected_output_mode(args, host),
        )
    if sub == "restart":
        parser = argparse.ArgumentParser(prog="aiops <host> docker restart")
        parser.add_argument("container")
        add_output_options(parser)
        args = parser.parse_args(rest[1:])
        require_safe_name("container", args.container)
        return run_builtin(host, f"docker restart {quoted(args.container)}", timeout=60, output_mode=selected_output_mode(args, host))
    raise AiopsError(f"unsupported docker subcommand: {sub}")


def command_service(host: HostConfig, rest: list[str]) -> int:
    if not rest:
        raise AiopsError("usage: aiops <host> service status|restart <name>")
    action = rest[0]
    if action == "status":
        parser = argparse.ArgumentParser(prog="aiops <host> service status")
        parser.add_argument("name")
        add_output_options(parser)
        args = parser.parse_args(rest[1:])
        require_safe_name("service", args.name)
        return run_builtin(
            host,
            f"systemctl status --no-pager -l {quoted(args.name)}",
            timeout=30,
            output_mode=selected_output_mode(args, host),
        )
    if action == "restart":
        parser = argparse.ArgumentParser(prog="aiops <host> service restart")
        parser.add_argument("name")
        add_output_options(parser)
        args = parser.parse_args(rest[1:])
        require_safe_name("service", args.name)
        return run_builtin(
            host,
            f"systemctl restart {quoted(args.name)} && systemctl is-active {quoted(args.name)}",
            timeout=60,
            output_mode=selected_output_mode(args, host),
        )
    raise AiopsError(f"unsupported service action: {action}")


def command_file(host: HostConfig, rest: list[str]) -> int:
    if len(rest) < 2 or rest[0] != "read":
        raise AiopsError("usage: aiops <host> file read <path> [--max-bytes N] [--raw|--json|--agent-json]")
    parser = argparse.ArgumentParser(prog="aiops <host> file read")
    parser.add_argument("path")
    parser.add_argument("--max-bytes", type=int, default=20000)
    add_output_options(parser)
    args = parser.parse_args(rest[1:])
    if not args.path.startswith("/"):
        raise AiopsError("file path must be absolute")
    require_int_range("--max-bytes", args.max_bytes, min_value=1)
    cmd = f"test -f {quoted(args.path)} && head -c {int(args.max_bytes)} {quoted(args.path)}"
    return run_builtin(host, cmd, timeout=30, output_mode=selected_output_mode(args, host))


def command_hosts(env: dict[str, str]) -> int:
    hosts = known_hosts(env)
    if not hosts and env.get("AIOPS_HTTPS_BASE"):
        hosts = [env.get("AIOPS_DEFAULT_HOST", "default")]
    for host in hosts:
        aliases = split_csv(env.get(f"AIOPS_HOST_{sanitize_host(host)}_ALIASES", ""))
        suffix = f" aliases={','.join(aliases)}" if aliases else ""
        print(f"{host}{suffix}")
    return 0


def usage() -> str:
    return """Usage:
  aiops hosts
  aiops <host> health
  aiops <host> [--root|--user] [--cwd DIR] [--timeout SEC] [--raw|--json|--agent-json] [--lock-key KEY] [--idempotency-key KEY] -- <cmd>
  aiops <host> batch [--raw|--json|--agent-json] --cmd <cmd> [--cmd <cmd> ...]
  aiops <host> batch -- <cmd1> <cmd2> ...
  aiops <host> docker ps [--all]
  aiops <host> docker logs <container> [--tail N]
  aiops <host> service status|restart <name>
  aiops <host> file read <absolute-path> [--max-bytes N]
  aiops <host> job <job_id> [--json]
  aiops <host> stdout|stderr <job_id> [--tail-bytes N]
"""


def main(argv: list[str]) -> int:
    err_mode = error_output_mode(argv)
    host_name = argv[0] if argv else ""
    try:
        if not argv or argv[0] in {"-h", "--help", "help"}:
            print(usage())
            return 0
        env = merged_env()
        err_mode = error_output_mode(argv, env)
        if argv[0] == "hosts":
            return command_hosts(env)
        host = host_config(argv[0], env)
        host_name = host.name
        err_mode = error_output_mode(argv, env)
        rest = argv[1:]
        if not rest:
            print(usage(), file=sys.stderr)
            return 2
        if rest[0] == "health":
            return command_health(host)
        if rest[0] == "inspect":
            return command_inspect(host, rest[1:])
        if rest[0] == "batch":
            return command_batch(host, rest[1:])
        if rest[0] == "docker":
            return command_docker(host, rest[1:])
        if rest[0] == "service":
            return command_service(host, rest[1:])
        if rest[0] == "file":
            return command_file(host, rest[1:])
        if rest[0] == "job":
            return command_job(host, rest[1:])
        if rest[0] in {"stdout", "stderr"}:
            return command_output(host, rest[0], rest[1:])
        return parse_run(rest, host)
    except AiopsError as exc:
        if err_mode == OUTPUT_AGENT_JSON:
            print_json_object(agent_error_payload(host_name, exc))
        else:
            print(f"[aiops] {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
